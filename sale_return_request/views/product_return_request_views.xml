<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_product_return_request_list" model="ir.ui.view">
        <field name="name">product.return.request.list</field>
        <field name="model">product.return.request</field>
        <field name="arch" type="xml">
            <list string="Return Requests">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="sale_order_id"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="reason"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_product_return_request_form" model="ir.ui.view">
        <field name="name">product.return.request.form</field>
        <field name="model">product.return.request</field>
        <field name="arch" type="xml">
            <form string="Return Request">
                <header>
                    <button name="action_submit" type="object" string="Submit"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Approve"
                            class="btn-primary"
                            invisible="state != 'submitted'"
                            groups="sale_return_request.group_return_manager"/>
                    <button name="action_reject" type="object" string="Reject"
                            invisible="state != 'submitted'"
                            groups="sale_return_request.group_return_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id" readonly="state != 'draft'"/>
                            <field name="sale_order_id" readonly="state != 'draft'"/>
                            <field name="product_id" domain="[('id', 'in', available_product_ids)]" readonly="state != 'draft'"/>
                            <field name="quantity" readonly="state != 'draft'"/>
                            <field name="available_product_ids" invisible="1"/>
                        </group>
                        <group>
                            <field name="reason" readonly="state != 'draft'"/>
                            <field name="reason_note"
                                   readonly="state != 'draft'"
                                   required="reason == 'other'"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View (default filters - bonus) -->
    <record id="view_product_return_request_search" model="ir.ui.view">
        <field name="name">product.return.request.search</field>
        <field name="model">product.return.request</field>
        <field name="arch" type="xml">
            <search string="Return Requests">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="sale_order_id"/>
                <field name="product_id"/>
                <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Submitted" name="filter_submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Approved" name="filter_approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected" name="filter_rejected" domain="[('state', '=', 'rejected')]"/>
                <separator/>
                <filter string="Created This Month" name="filter_this_month"
                        domain="[('create_date', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Customer" name="group_by_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Month" name="group_by_month" context="{'group_by': 'create_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_product_return_request" model="ir.actions.act_window">
        <field name="name">Return Requests</field>
        <field name="res_model">product.return.request</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_product_return_request_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new return request
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_product_return_request_root"
              name="Return Requests"
              parent="sale.sale_menu_root"
              action="action_product_return_request"
              sequence="20"/>

</odoo>
